{
    "name": "nomanurrahman/laravel-markdown-rag",
    "description": "Transform Markdown files into AI-ready context with smart chunking and RAG capabilities for Laravel",
    "keywords": [
        "nomanurrahman",
        "laravel-markdown-rag"
    ],
    "homepage": "https://github.com/nomanurrahman/laravel-markdown-rag",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "nomanur rahman",
            "email": "nomanurrahman@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "livewire/livewire": "^4.0",
        "laravel/ai": "^0.2.5"
    },
    "require-dev": {
        "orchestra/testbench": "^9.16",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Nomanurrahman\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nomanurrahman\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"

    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nomanurrahman\\LaravelMarkdownRAGServiceProvider"
            ],
            "aliases": {
                "LaravelMarkdownRAG": "Nomanurrahman\\LaravelMarkdownRAGFacade"
            }
        }
    }
}
